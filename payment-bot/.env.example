# Token do bot de pagamento (obtido no Discord Developer Portal)
DISCORD_TOKEN=seu_token_aqui

# ID do aplicativo/bot de pagamento
CLIENT_ID=seu_client_id_aqui

# ID da guild onde o bot de pagamento opera (opcional)
GUILD_ID=seu_guild_id_aqui

# Token do Mercado Pago para processar pagamentos
MERCADO_PAGO_TOKEN=seu_token_mercado_pago_aqui

# Preço da assinatura mensal (em centavos, ex: 5000 = R$ 50,00)
SUBSCRIPTION_PRICE=5000

# ID do cargo que será atribuído aos clientes com assinatura ativa
SUBSCRIBER_ROLE_ID=seu_role_id_aqui
