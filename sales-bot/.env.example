# Token do bot de vendas (obtido no Discord Developer Portal)
DISCORD_TOKEN=seu_token_aqui

# ID do aplicativo/bot de vendas
CLIENT_ID=seu_client_id_aqui

# ID da guild onde o bot opera (opcional)
# Se não definido, os comandos serão registrados globalmente (pode levar até 1 hora)
# Para desenvolvimento, use o GUILD_ID do seu servidor de testes para registrar instantaneamente
GUILD_ID=seu_guild_id_aqui
